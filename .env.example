# Required: token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Public HTTPS URL of your deployment (enables webhook mode).
# Leave unset/localhost to run in long-polling mode locally.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Where the SQLite database is stored (mount a persistent volume here).
DATA_DIR=/data

# Port (Railway sets this automatically).
PORT=8000

# Optional: comma-separated Telegram user IDs that can always use admin commands
# (e.g. the bot owner) even if not a group admin.
BOT_ADMINS=
