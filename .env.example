# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Railway public URL (enables webhook mode)
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Number of recent media messages to keep before deleting older ones (default: 10)
MEDIA_KEEP_COUNT=10

# Backup bot links to post periodically (one per line)
BACKUP_LINKS=https://t.me/your_backup_bot_1
https://t.me/your_backup_bot_2

# How often to post backup links in seconds (default: 21600 = 6 hours)
BACKUP_INTERVAL_SECONDS=21600

# Comma-separated chat IDs to post backup links to.
# Leave empty to auto-post to every chat the bot has seen media in.
BACKUP_CHAT_IDS=

PORT=8000
